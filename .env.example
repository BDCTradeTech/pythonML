# Copiar a .env y completar los valores
# cp .env.example .env   (Linux/Mac)  o  copy .env.example .env  (Windows)

# SMTP - Para enviar emails (registro, reinicio de contraseña desde Admin)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-contraseña-de-aplicacion
SMTP_FROM=tu-email@gmail.com
SMTP_FROM_NAME=BDC systems

# Para Gmail: crear contraseña de aplicación en https://myaccount.google.com/apppasswords
